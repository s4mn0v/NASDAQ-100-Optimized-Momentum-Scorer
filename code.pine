//@version=6
indicator("The Indicator - Optimized", overlay = true, max_labels_count = 500)

// --- INPUTS ---
hmaL_len    = input.int(21, "HMA Largo", group="HMA")
hmaS_len    = input.int(8, "HMA Corto", group="HMA")
rsx_len     = input.int(14, "RSX Length", group="RSX")
atr_len     = input.int(100, "ATR Length", group="ATR")
atr_mult    = input.float(3.0, "ATR Mult", group="ATR")
bbLen       = input.int(20, "BB Length", group="Volatility")
minBBW      = input.float(0.5, "Min BB Width %", group="Volatility")
maxAge      = input.int(10, "Max Trend Age (Bars)", group="Contexto")
macd_ma     = input.int(34, "MACD MA", group="MACD")
macd_sig    = input.int(9, "MACD Signal", group="MACD")
maxSpread   = input.float(2.0, "Max Spread (Ticks)", group="Filtros")

// --- LOGIC: SESSION & VOLATILITY ---
var float dHigh = na, var float dLow  = na
if timeframe.change("D")
    dHigh := high, dLow := low
else
    dHigh := math.max(dHigh, high), dLow := math.min(dLow, low)

// Daily Range Score Logic
dailyMid = (dHigh + dLow) / 2
priceAboveDailyMid = close > dailyMid

// ATR Filter
atrVal = ta.atr(atr_len)
// Filtro: El movimiento actual debe tener volatilidad mínima comparada con ATR
volatilityOK = ta.tr > (atrVal * 0.1) 

// Spread Filter (v6 ask/bid)
currentSpread = (ask - bid) / syminfo.mintick
spreadOK = na(currentSpread) or currentSpread <= maxSpread

// Bollinger Band Width
[bbM, bbU, bbL] = ta.bb(close, bbLen, 2.0)
bbw = ((bbU - bbL) / bbM) * 100
marketActive = bbw > minBBW

// --- MODULES ---
f_hma(src, len) => ta.wma(2 * ta.wma(src, math.round(len/2)) - ta.wma(src, len), math.round(math.sqrt(len)))
hmaL = f_hma(close, hmaL_len)
hmaS = f_hma(close, hmaS_len)
hmaUp = hmaS > hmaL
hmaSlope = hmaS - hmaS[1]

// Trend Age
var int trendAge = 0
if ta.change(hmaUp)
    trendAge := 0
else
    trendAge += 1

// Jurik RSX
f_rsx(src, len) =>
    f18 = 3/(len+2), f20 = 1-f18
    var f28=0.0, var f30=0.0, var f38=0.0, var f40=0.0, var f48=0.0, var f50=0.0, var v20=0.0
    v8 = src*100 - nz(src[1])*100
    f28 := f20*nz(f28[1]) + f18*v8
    f30 := f18*f28 + f20*nz(f30[1])
    vC = f28*1.5 - f30*0.5
    f38 := f20*nz(f38[1]) + f18*vC
    f40 := f18*f38 + f20*nz(f40[1])
    v10 = f38*1.5 - f40*0.5
    f48 := f20*nz(f48[1]) + f18*v10
    f50 := f18*f48 + f20*nz(f50[1])
    v14 = f48*1.5 - f50*0.5
    var f58=0.0, var f60=0.0, var f68=0.0, var f70=0.0, var f78=0.0, var f80=0.0
    f58 := f20*nz(f58[1]) + f18*math.abs(v8)
    f60 := f18*f58 + f20*nz(f60[1])
    v18 = f58*1.5 - f60*0.5
    f68 := f20*nz(f68[1]) + f18*v18
    f70 := f18*f68 + f20*nz(f70[1])
    v1C = f68*1.5 - f70*0.5
    f78 := f20*nz(f78[1]) + f18*v1C
    f80 := f18*f78 + f20*nz(f80[1])
    v20 := f78*1.5 - f80*0.5
    v20 > 0 ? (v14/v20 + 1)*50 : 50
rsxVal = f_rsx(close, rsx_len)

// MACD Impulse
calc_zlema(src, len) =>
    e1 = ta.ema(src, len), e2 = ta.ema(e1, len)
    e1 + (e1 - e2)
miMA = calc_zlema(hlc3, macd_ma)
sb = ta.sma(miMA, macd_sig)
macdUp = (miMA - sb) > 0

// Pivots Trigger
ph = ta.pivothigh(high, 3, 2), pl = ta.pivotlow(low, 3, 2)
triggerLong  = ta.crossover(close, ta.valuewhen(not na(ph), ph, 0))
triggerShort = ta.crossunder(close, ta.valuewhen(not na(pl), pl, 0))

// --- SCORING SYSTEM ---
int score = 0
score += hmaUp ? 2 : -2
score += macdUp ? 1 : -1
score += (rsxVal > 50) ? 1 : -1
score += (hmaSlope > 0) ? 1 : -1
score += (close > ta.ema(close, 200)) ? 1 : -1
score += priceAboveDailyMid ? 1 : -1 // Uso de dHigh/dLow

// --- PERMISSION & STATE MACHINE ---
var bool entryAllowed = true
if ta.change(hmaUp)
    entryAllowed := true

// --- FINAL SIGNALS ---
// Se agrega spreadOK, volatilityOK y uso indirecto de atr_mult para potenciales niveles (opcional)
longCond = entryAllowed and marketActive and hmaUp and score >= 4 and triggerLong and trendAge <= maxAge and spreadOK and volatilityOK
shortCond = entryAllowed and marketActive and not hmaUp and score <= -4 and triggerShort and trendAge <= maxAge and spreadOK and volatilityOK

if longCond or shortCond
    entryAllowed := false 

plotshape(longCond, "Strong Buy", shape.labelup, location.belowbar, color.lime, text="+", textcolor=color.black, size=size.small)
plotshape(shortCond, "Strong Sell", shape.labeldown, location.abovebar, color.red, text="-", textcolor=color.white, size=size.small)

// --- VISUALS ---
plot(hmaS, "HMA S", color=hmaUp ? color.lime : color.orange, linewidth=2)
plot(bbU, "BB Upper", color=color.new(color.gray, 80))
plot(bbL, "BB Lower", color=color.new(color.gray, 80))
plot(dHigh, "Daily High", color=color.new(color.red, 60), style=plot.style_steplinebr)
plot(dLow, "Daily Low", color=color.new(color.green, 60), style=plot.style_steplinebr)

// --- DASHBOARD ---
var table panel = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 30), border_width=1)
if barstate.islast
    table.cell(panel, 0, 0, "Score", text_color=color.white)
    table.cell(panel, 1, 0, str.tostring(score), text_color=score >= 4 ? color.lime : score <= -4 ? color.red : color.white)
    table.cell(panel, 0, 1, "Market", text_color=color.white)
    table.cell(panel, 1, 1, marketActive ? "ACTIVE" : "LATERAL", text_color=marketActive ? color.lime : color.orange)
    table.cell(panel, 0, 2, "Age", text_color=color.white)
    table.cell(panel, 1, 2, str.tostring(trendAge), text_color=color.white)
    table.cell(panel, 0, 3, "Spread", text_color=color.white)
    table.cell(panel, 1, 3, str.tostring(currentSpread, "#.#"), text_color=spreadOK ? color.lime : color.red)

